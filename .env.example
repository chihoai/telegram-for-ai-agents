TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# Optional: label for the Telegram account/session (useful for multiple accounts)
# TELEGRAM_ACCOUNT_LABEL=default

# Optional. Defaults to ~/.config/telegram-for-agents/telegram.session
# TELEGRAM_SESSION_PATH=/Users/you/.config/telegram-for-agents/telegram.session

# Optional proxy URL (IP-auth proxies work without user/password):
# TELEGRAM_PROXY_URL=socks5://203.0.113.10:1080
# TELEGRAM_PROXY_URL=http://203.0.113.10:8080
# TELEGRAM_PROXY_URL=https://203.0.113.10:8443

# Optional Postgres for app/CRM data (recommended to match VPS setup)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/tgchats

# Optional AI mode. If omitted, defaults to:
# - gemini when GEMINI_API_KEY is set
# - openclaw when OPENCLAW_BASE_URL is set
# AI_MODE=gemini

# Gemini mode
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash

# OpenClaw mode (OpenAI-compatible chat completion endpoint)
# OPENCLAW_BASE_URL=http://localhost:3000
# OPENCLAW_API_KEY=optional_token
# OPENCLAW_MODEL=openai-codex/gpt-5.3-codex

# Optional timeout for AI calls (milliseconds)
# AI_TIMEOUT_MS=30000
