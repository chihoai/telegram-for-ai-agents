{
  "id": "bd.followup",
  "name": "BD Follow-Up",
  "description": "Revive warm business development and partnership threads without cold outreach.",
  "personas": ["crypto-bd", "partnerships", "growth"],
  "taskCategories": ["bd", "follow_up", "partnerships"],
  "discover": {
    "mode": "tagged_dialogs",
    "limit": 10,
    "requiredAnyTags": ["Lead", "Partner", "BD"],
    "staleDays": 2,
    "maxHistoryMessages": 12
  },
  "allowedTools": [
    "dialogs.list",
    "chat.read",
    "summary.refresh",
    "tags.set",
    "company.link",
    "tasks.add",
    "nudge.generate",
    "messages.send"
  ],
  "allowedActions": [
    "refresh_summary",
    "set_tags",
    "link_company",
    "create_task",
    "send_message",
    "team_handoff"
  ],
  "budget": {
    "maxCandidates": 10,
    "maxToolCalls": 40,
    "maxAiCalls": 12,
    "maxRetriesPerStep": 2,
    "maxOutboundMessages": 5,
    "maxWallTimeSeconds": 300
  },
  "guardrails": {
    "requireExistingThread": true,
    "maxInactiveDays": 30,
    "dedupeWindowDays": 14,
    "blockIfLatestMessageChanged": true,
    "abortOnGuardrailFailure": true,
    "allowSend": true
  },
  "verification": {
    "verifyCrmMutations": true,
    "verifyMessageSend": true,
    "requireHistoryEcho": true
  },
  "outputs": ["summary", "task", "message", "handoff_note", "agent_log.json"],
  "defaultMessageStyle": "concise",
  "plannerPrompt": "Prioritize warm BD and partner threads that have stalled but still show intent. Prefer crisp follow-ups that move toward a concrete next step."
}
