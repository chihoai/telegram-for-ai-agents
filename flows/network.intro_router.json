{
  "id": "network.intro_router",
  "name": "Network Intro Router",
  "description": "Triage warm intro and network coordination threads, deciding whether to follow up directly or hand off with context.",
  "personas": ["networking", "bd", "founder"],
  "taskCategories": ["network", "intros", "routing", "follow_up"],
  "discover": {
    "mode": "recent_dialogs",
    "limit": 10,
    "requiredAnyTags": ["Network", "Connector", "Introducer", "Partner"],
    "staleDays": 1,
    "maxHistoryMessages": 12
  },
  "allowedTools": [
    "dialogs.list",
    "chat.read",
    "summary.refresh",
    "tags.set",
    "company.link",
    "tasks.add",
    "nudge.generate",
    "messages.send"
  ],
  "allowedActions": [
    "refresh_summary",
    "set_tags",
    "link_company",
    "create_task",
    "send_message",
    "team_handoff"
  ],
  "budget": {
    "maxCandidates": 10,
    "maxToolCalls": 40,
    "maxAiCalls": 12,
    "maxRetriesPerStep": 2,
    "maxOutboundMessages": 5,
    "maxWallTimeSeconds": 300
  },
  "guardrails": {
    "requireExistingThread": true,
    "maxInactiveDays": 30,
    "dedupeWindowDays": 14,
    "blockIfLatestMessageChanged": true,
    "abortOnGuardrailFailure": true,
    "allowSend": true
  },
  "verification": {
    "verifyCrmMutations": true,
    "verifyMessageSend": true,
    "requireHistoryEcho": true
  },
  "outputs": ["summary", "task", "message", "handoff_note", "agent_log.json"],
  "defaultMessageStyle": "concise",
  "plannerPrompt": "Focus on warm intros and network routing. Prefer direct follow-up only when the thread already has context and the next ask is clear; otherwise prepare a precise handoff."
}
