{
  "id": "support.first_response",
  "name": "Support First Response",
  "description": "Handle low-risk support and user issue threads with fast, bounded first responses and escalation paths.",
  "personas": ["support", "community", "ops"],
  "taskCategories": ["support", "users", "triage", "follow_up"],
  "discover": {
    "mode": "unread_dialogs",
    "limit": 10,
    "requiredAnyTags": ["Support", "User", "Customer"],
    "minUnreadCount": 1,
    "maxHistoryMessages": 12
  },
  "allowedTools": [
    "dialogs.list",
    "chat.read",
    "summary.refresh",
    "tags.set",
    "tasks.add",
    "nudge.generate",
    "messages.send"
  ],
  "allowedActions": [
    "refresh_summary",
    "set_tags",
    "create_task",
    "send_message",
    "team_handoff"
  ],
  "budget": {
    "maxCandidates": 10,
    "maxToolCalls": 40,
    "maxAiCalls": 12,
    "maxRetriesPerStep": 2,
    "maxOutboundMessages": 5,
    "maxWallTimeSeconds": 300
  },
  "guardrails": {
    "requireExistingThread": true,
    "maxInactiveDays": 14,
    "dedupeWindowDays": 7,
    "blockIfLatestMessageChanged": true,
    "abortOnGuardrailFailure": true,
    "allowSend": true
  },
  "verification": {
    "verifyCrmMutations": true,
    "verifyMessageSend": true,
    "requireHistoryEcho": true
  },
  "outputs": ["summary", "task", "message", "handoff_note", "agent_log.json"],
  "defaultMessageStyle": "friendly",
  "plannerPrompt": "Only respond when a low-risk first response is appropriate. If the issue looks sensitive, ambiguous, or operationally risky, create a handoff instead of improvising."
}
